---
import { useTranslations, type Lang } from '../i18n/ui';
import { projects, type Project } from '../data/projects';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const sectionId = t('nav.projects.href').replace('#', '');

function getTitle(p: Project): string {
  return typeof p.title === 'string' ? p.title : p.title[lang];
}
---

<section
  id={sectionId}
  aria-labelledby="projects-title"
  class="py-24"
>
  <div class="mx-auto max-w-5xl px-6">

    <!-- Section heading -->
    <div class="mb-12 flex items-center gap-4" data-reveal>
      <span class="font-mono text-sm text-accent" aria-hidden="true">02.</span>
      <h2
        id="projects-title"
        class="whitespace-nowrap font-heading text-xl font-semibold text-text-primary"
      >
        {t('projects.title')}
      </h2>
      <div class="h-px flex-1 bg-text-tertiary/20" aria-hidden="true"></div>
    </div>

    <!-- Cards grid -->
    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((project, i) => {
        const title = getTitle(project);
        const desc = project.description[lang];
        const badge = project.badge ? project.badge[lang] : undefined;

        return (
          <article
            data-reveal
            style={`animation-delay: ${i * 90}ms`}
            class:list={[
              'flex flex-col gap-5 rounded-lg border p-6',
              'bg-surface',
              project.wip
                ? 'border-dashed border-text-tertiary/25 opacity-70'
                : [
                    'group',
                    'border-text-tertiary/20',
                    'motion-safe:hover:-translate-y-1',
                    'motion-safe:transition-transform',
                    'motion-safe:duration-200',
                  ],
            ]}
          >
            <!-- Card top: folder icon + links -->
            <div class="flex items-start justify-between">
              <svg
                width="36"
                height="36"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-accent"
                aria-hidden="true"
              >
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
              </svg>

              <div class="flex items-center gap-3">
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${t('projects.github.label')}: ${title}`}
                    class="text-text-tertiary transition-colors duration-150 hover:text-accent"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                    </svg>
                  </a>
                )}
                {project.demo && (
                  <a
                    href={project.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${t('projects.demo.label')}: ${title}`}
                    class="text-text-tertiary transition-colors duration-150 hover:text-accent"
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>

            <!-- Title + badge -->
            <div class="flex flex-wrap items-center gap-3">
              <h3
                class:list={[
                  'font-heading text-lg font-semibold text-text-primary',
                  !project.wip && [
                    'motion-safe:transition-colors',
                    'motion-safe:duration-150',
                    'motion-safe:group-hover:text-accent',
                  ],
                ]}
              >
                {title}
              </h3>
              {badge && (
                <span class="rounded border border-text-tertiary/30 px-2 py-0.5 font-mono text-xs text-text-tertiary">
                  {badge}
                </span>
              )}
            </div>

            <!-- Description -->
            <p class="flex-1 text-sm leading-relaxed text-text-secondary">
              {desc}
            </p>

            <!-- Tags -->
            <ul class="flex flex-wrap gap-x-4 gap-y-1" role="list">
              {project.tags.map((tag) => (
                <li class="font-mono text-xs text-text-tertiary">{tag}</li>
              ))}
            </ul>
          </article>
        );
      })}
    </div>

  </div>
</section>

<script>
  const motionOk = !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (motionOk) {
    document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => {
      el.classList.add('reveal-hidden');
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            el.classList.remove('reveal-hidden');
            el.classList.add('reveal-visible');
            el.addEventListener('animationend', () => el.classList.remove('reveal-visible'), { once: true });
            observer.disconnect();
          }
        },
        { threshold: 0.1, rootMargin: '0px 0px -60px 0px' },
      );
      observer.observe(el);
    });
  }
</script>
