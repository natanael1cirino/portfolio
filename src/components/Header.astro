---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const homeHref = lang === 'pt' ? '/' : '/en/';
---

<header class="fixed left-0 right-0 top-0 z-50 border-b border-white/[0.06] bg-surface/80 backdrop-blur-md">
  <nav
    class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6"
    aria-label={t('nav.label')}
  >
    <a href={homeHref} class="flex items-baseline" aria-label="NC — Home">
      <span class="font-mono text-xl font-medium text-accent">NC</span>
      <span class="font-mono text-xl text-text-tertiary">.</span>
    </a>

    <div class="flex items-center gap-6">
      <ul class="hidden items-center gap-6 md:flex" role="list">
        <li>
          <a href={t('nav.about.href')} class="flex items-baseline gap-1.5 text-sm text-text-secondary transition-colors duration-150 hover:text-text-primary">
            <span class="font-mono text-xs text-accent">01.</span>
            {t('nav.about')}
          </a>
        </li>
        <li>
          <a href={t('nav.projects.href')} class="flex items-baseline gap-1.5 text-sm text-text-secondary transition-colors duration-150 hover:text-text-primary">
            <span class="font-mono text-xs text-accent">02.</span>
            {t('nav.projects')}
          </a>
        </li>
        <li>
          <a href={t('nav.contact.href')} class="flex items-baseline gap-1.5 text-sm text-text-secondary transition-colors duration-150 hover:text-text-primary">
            <span class="font-mono text-xs text-accent">03.</span>
            {t('nav.contact')}
          </a>
        </li>
      </ul>

      <a
        href={t('nav.lang.href')}
        aria-label={t('nav.lang.label')}
        class="rounded border border-text-tertiary/40 px-2.5 py-1 font-mono text-xs text-text-secondary transition-colors duration-150 hover:border-accent hover:text-accent"
      >
        {t('nav.lang.code')}
      </a>
    </div>
  </nav>
</header>
